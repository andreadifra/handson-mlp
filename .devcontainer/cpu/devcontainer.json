{
  "name": "handson-mlp (CPU)",
  "build": {
    "dockerfile": "../../docker/Dockerfile",
    "context": "../..",
    "options": [
      "-t",
      "handson-mlp-devcontainer:cpu"
    ],
    "args": {
      "PT_VARIANT": "cpu"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "overrideCommand": true,
  "init": true,
  "userEnvProbe": "none",
  "runArgs": [
    "--shm-size=1g"
  ],
  "mounts": [
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude/skills,target=/root/.claude/skills,type=bind,readonly",
		"source=${localEnv:HOME}${localEnv:USERPROFILE}/.agents/skills,target=/root/.agents/skills,type=bind,readonly",
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.copilot/mcp-config.json,target=/root/.copilot/mcp-config.json,type=bind,readonly"
	],
  "containerUser": "root",
  "remoteUser": "root",
  "remoteEnv": {
    "PATH": "/root/.local/bin:/opt/venvs/handson-mlp/bin:${containerEnv:PATH}"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {}
  },
  "postCreateCommand": "sh .devcontainer/scripts/post-create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/opt/venvs/handson-mlp/bin/python",
        "python.terminal.activateEnvironment": false,
        "jupyter.notebookFileRoot": "${containerWorkspaceFolder}"
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "GitHub.copilot-chat"
      ]
    }
  }
}